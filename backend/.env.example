# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=nepalikala
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django Admin Configuration
DJANGO_SECRET_KEY=your-very-secret-django-key-change-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# FastAPI Configuration
SECRET_KEY=your-very-secret-fastapi-key-change-in-production
DEBUG=False
HOST=0.0.0.0
PORT=8001

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,http://localhost:8000,http://localhost:8080,http://127.0.0.1:5500

# JWT Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# File Upload
MAX_UPLOAD_SIZE=10485760

# Revenue Share Configuration
ARTIST_REVENUE_SHARE=0.80
PLATFORM_FEE=0.20

# Email Configuration (for password reset, notifications)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Payment Gateway (Khalti/eSewa)
KHALTI_PUBLIC_KEY=your_khalti_public_key
KHALTI_SECRET_KEY=your_khalti_secret_key
ESEWA_MERCHANT_ID=your_esewa_merchant_id

# Cloud Storage (AWS S3 or similar)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=nepalikala-media
AWS_S3_REGION_NAME=ap-south-1
